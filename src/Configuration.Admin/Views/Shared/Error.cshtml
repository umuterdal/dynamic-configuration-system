@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="page-header">
    <h2>
        <i class="bi bi-exclamation-triangle me-2 text-danger"></i>Error
    </h2>
</div>

<div class="card" style="max-width: 600px;">
    <div class="card-body p-4">
        <div class="delete-icon">
            <i class="bi bi-exclamation-circle"></i>
        </div>
        <h5 class="mb-2">Something went wrong</h5>
        <p class="text-muted mb-3">An error occurred while processing your request.</p>

        @if (Model.ShowRequestId)
        {
            <div class="bg-light rounded p-3 mb-3">
                <small class="text-muted">Request ID</small>
                <code class="d-block mt-1">@Model.RequestId</code>
            </div>
        }

        <a asp-controller="Configuration" asp-action="Index" class="btn btn-primary">
            <i class="bi bi-house me-1"></i>Back to Configurations
        </a>
    </div>
</div>
