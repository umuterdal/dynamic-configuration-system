<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Dynamic Configuration</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Configuration.Admin.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
            <div class="container-fluid px-4">
                <a class="navbar-brand fw-semibold" asp-controller="Configuration" asp-action="Index">
                    <i class="bi bi-gear-wide-connected me-2"></i>Dynamic Configuration
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav"
                        aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <a class="nav-link" href="http://localhost:5001/swagger" target="_blank">
                                <i class="bi bi-box-arrow-up-right me-1"></i>API Docs
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="flex-shrink-0">
        <div class="container-fluid px-4 py-4">
            @RenderBody()
        </div>
    </main>

    <footer class="footer mt-auto py-3 bg-light border-top">
        <div class="container-fluid px-4">
            <div class="d-flex justify-content-between align-items-center">
                <span class="text-muted small">Dynamic Configuration System &copy; @DateTime.Now.Year</span>
                <span class="text-muted small">
                    <i class="bi bi-database me-1"></i>MongoDB:
                    <span id="mongodb-status" class="fw-semibold">
                        <i class="bi bi-arrow-repeat spin"></i> Kontrol ediliyor...
                    </span>
                    <span class="mx-2">|</span>
                    <i class="bi bi-code-slash me-1"></i>.NET 8
                </span>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        (function () {
            var statusEl = document.getElementById('mongodb-status');
            if (!statusEl) return;

            fetch('/Configuration/Health')
                .then(function (r) { return r.json(); })
                .then(function (data) {
                    if (data.mongoDB === 'healthy') {
                        statusEl.innerHTML = '<span style="color:#16a34a"><i class="bi bi-check-circle-fill me-1"></i>Çalışıyor</span>';
                    } else {
                        statusEl.innerHTML = '<span style="color:#dc2626"><i class="bi bi-x-circle-fill me-1"></i>Bağlantı yok</span>';
                    }
                })
                .catch(function () {
                    statusEl.innerHTML = '<span style="color:#dc2626"><i class="bi bi-x-circle-fill me-1"></i>Bağlantı yok</span>';
                });
        })();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
