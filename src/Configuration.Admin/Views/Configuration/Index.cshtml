@model IEnumerable<Configuration.Domain.Entities.ConfigurationRecord>

@{
    ViewData["Title"] = "Configurations";
    var applicationName = ViewBag.ApplicationName as string;
}

<div class="page-header">
    <h2>
        <i class="bi bi-list-ul me-2 text-primary"></i>
        Configurations @(string.IsNullOrEmpty(applicationName) ? "" : $"- {applicationName}")
    </h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>New Configuration
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-2"></i>@TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="filter-bar">
    <form asp-action="Index" method="get">
        <div class="row g-3 align-items-end">
            <div class="col-md-5">
                <label class="form-label mb-1">Application Name</label>
                <input type="text" name="applicationName" value="@applicationName"
                       class="form-control" placeholder="e.g. SERVICE-A, SERVICE-B" id="searchInput" />
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-search me-1"></i>Filter
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary ms-1">
                    <i class="bi bi-x-lg me-1"></i>Clear
                </a>
            </div>
            <div class="col-auto ms-auto">
                <span class="text-muted small">
                    <i class="bi bi-info-circle me-1"></i>@Model.Count() record(s)
                </span>
            </div>
        </div>
    </form>
</div>

<div class="table-container">
    <div class="table-responsive">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th style="width: 130px;">ID</th>
                    <th>Name</th>
                    <th style="width: 90px;">Type</th>
                    <th>Value</th>
                    <th style="width: 90px;">Status</th>
                    <th>Application</th>
                    <th style="width: 140px;">Actions</th>
                </tr>
            </thead>
            <tbody id="configurationTable">
                @if (Model.Any())
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="id-cell" title="@item.Id">@item.Id</td>
                            <td class="fw-medium">@item.Name</td>
                            <td class="type-cell">@item.Type</td>
                            <td class="value-cell" title="@item.Value">@item.Value</td>
                            <td>
                                @if (item.IsActive == 1)
                                {
                                    <span class="badge-active">
                                        <i class="bi bi-check-circle-fill me-1"></i>Active
                                    </span>
                                }
                                else
                                {
                                    <span class="badge-inactive">
                                        <i class="bi bi-x-circle-fill me-1"></i>Inactive
                                    </span>
                                }
                            </td>
                            <td>
                                <span class="text-muted">@item.ApplicationName</span>
                            </td>
                            <td>
                                <div class="action-btns">
                                    <a asp-action="Edit" asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-primary" title="Edit">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-danger" title="Delete">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7">
                            <div class="empty-state">
                                <i class="bi bi-inbox"></i>
                                <p class="mb-0">No configurations found</p>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('searchInput').addEventListener('keyup', function () {
            var filter = this.value.toLowerCase();
            var rows = document.querySelectorAll('#configurationTable tr');
            rows.forEach(function (row) {
                if (row.cells.length < 6) return;
                var name = row.cells[1]?.textContent.toLowerCase() || '';
                row.style.display = name.includes(filter) ? '' : 'none';
            });
        });

        function escapeHtml(str) {
            if (!str) return '';
            var div = document.createElement('div');
            div.appendChild(document.createTextNode(str));
            return div.innerHTML;
        }

        (function () {
            var applicationName = '@applicationName';
            var tbody = document.getElementById('configurationTable');

            function refreshTable() {
                var url = '/Configuration/GetConfigurations';
                if (applicationName) url += '?applicationName=' + encodeURIComponent(applicationName);

                fetch(url)
                    .then(function (r) { return r.json(); })
                    .then(function (data) {
                        if (!data || data.length === 0) {
                            tbody.innerHTML = '<tr><td colspan="7"><div class="empty-state"><i class="bi bi-inbox"></i><p class="mb-0">No configurations found</p></div></td></tr>';
                            return;
                        }
                        var html = '';
                        data.forEach(function (item) {
                            var status = item.isActive === 1
                                ? '<span class="badge-active"><i class="bi bi-check-circle-fill me-1"></i>Active</span>'
                                : '<span class="badge-inactive"><i class="bi bi-x-circle-fill me-1"></i>Inactive</span>';
                            html += '<tr>'
                                + '<td class="id-cell" title="' + escapeHtml(item.id) + '">' + escapeHtml(item.id) + '</td>'
                                + '<td class="fw-medium">' + escapeHtml(item.name) + '</td>'
                                + '<td class="type-cell">' + escapeHtml(item.type) + '</td>'
                                + '<td class="value-cell" title="' + escapeHtml(item.value) + '">' + escapeHtml(item.value) + '</td>'
                                + '<td>' + status + '</td>'
                                + '<td><span class="text-muted">' + escapeHtml(item.applicationName) + '</span></td>'
                                + '<td><div class="action-btns">'
                                + '<a href="/Configuration/Edit?id=' + encodeURIComponent(item.id) + '" class="btn btn-sm btn-outline-primary" title="Edit"><i class="bi bi-pencil"></i></a> '
                                + '<a href="/Configuration/Delete?id=' + encodeURIComponent(item.id) + '" class="btn btn-sm btn-danger" title="Delete"><i class="bi bi-trash"></i></a>'
                                + '</div></td></tr>';
                        });
                        tbody.innerHTML = html;

                        var countEl = document.querySelector('.text-muted.small');
                        if (countEl) countEl.innerHTML = '<i class="bi bi-info-circle me-1"></i>' + data.length + ' record(s)';
                    })
                    .catch(function () { });
            }

            setInterval(refreshTable, 30000);
        })();
    </script>
}
