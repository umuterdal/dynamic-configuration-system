@model Configuration.Domain.Entities.ConfigurationRecord

@{
    ViewData["Title"] = "Delete Configuration";
}

<div class="page-header">
    <h2>
        <i class="bi bi-trash me-2 text-danger"></i>Delete Configuration
    </h2>
    <a asp-action="Index" asp-route-applicationName="@Model.ApplicationName" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Back to List
    </a>
</div>

<div class="card delete-card">
    <div class="card-body">
        <div class="delete-icon">
            <i class="bi bi-exclamation-triangle"></i>
        </div>
        <h5 class="mb-1 fw-semibold">Are you sure?</h5>
        <p class="text-muted mb-3">This action will permanently delete this configuration.</p>

        <dl class="row mb-0">
            <dt class="col-sm-4">Name</dt>
            <dd class="col-sm-8">@Model.Name</dd>

            <dt class="col-sm-4">Type</dt>
            <dd class="col-sm-8">
                <span class="type-cell">@Model.Type</span>
            </dd>

            <dt class="col-sm-4">Value</dt>
            <dd class="col-sm-8">
                <code class="bg-light px-2 py-1 rounded">@Model.Value</code>
            </dd>

            <dt class="col-sm-4">Status</dt>
            <dd class="col-sm-8">
                @if (Model.IsActive == 1)
                {
                    <span class="badge-active">Active</span>
                }
                else
                {
                    <span class="badge-inactive">Inactive</span>
                }
            </dd>

            <dt class="col-sm-4">Application</dt>
            <dd class="col-sm-8">@Model.ApplicationName</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" method="post" class="mt-4">
    <input type="hidden" asp-for="Id" />
    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-danger">
            <i class="bi bi-trash me-1"></i>Delete
        </button>
        <a asp-action="Index" asp-route-applicationName="@Model.ApplicationName" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>
