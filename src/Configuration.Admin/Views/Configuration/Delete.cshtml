@model Configuration.Domain.Entities.ConfigurationRecord

@{
    ViewData["Title"] = "Delete Configuration";
}

<div class="container mt-4">
    <h2>Delete Configuration</h2>
    <hr />

    <div class="alert alert-danger">
        <h4>Are you sure you want to delete this configuration?</h4>
    </div>

    <div class="card" style="width: 30rem;">
        <div class="card-body">
            <h5 class="card-title">@Model.Name</h5>
            <dl class="row">
                <dt class="col-sm-4">ID</dt>
                <dd class="col-sm-8">@Model.Id</dd>

                <dt class="col-sm-4">Name</dt>
                <dd class="col-sm-8">@Model.Name</dd>

                <dt class="col-sm-4">Type</dt>
                <dd class="col-sm-8">@Model.Type</dd>

                <dt class="col-sm-4">Value</dt>
                <dd class="col-sm-8">@Model.Value</dd>

                <dt class="col-sm-4">Active</dt>
                <dd class="col-sm-8">@(Model.IsActive == 1 ? "Yes" : "No")</dd>

                <dt class="col-sm-4">Application</dt>
                <dd class="col-sm-8">@Model.ApplicationName</dd>
            </dl>
        </div>
    </div>

    <form asp-action="Delete" method="post" class="mt-3">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" asp-route-applicationName="@Model.ApplicationName" class="btn btn-secondary">Cancel</a>
    </form>
</div>
